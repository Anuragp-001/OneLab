# ============================================================================
# Onelab Reconciliation — environment configuration
# Copy this file to `.env` and tweak values as needed.
# ============================================================================

# --- Synthetic data generation -------------------------------------------
# Random seed for deterministic, reproducible datasets across runs.
DATA_SEED=42

# How many base transactions to generate (>= 500 for meaningful analysis).
NUM_TRANSACTIONS=600

# Reconciliation period — the calendar month to analyse.
RECON_MONTH=4
RECON_YEAR=2026

# --- Optional API keys ---------------------------------------------------
# This project does NOT require any external API keys to run.
# The placeholder below is here for future extensions (e.g. an
# AI-generated executive summary, or fetching live FX rates).
# Leave blank if not using.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
